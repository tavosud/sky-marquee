{
  "name": "@tavosud/sky-marquee",
  "version": "1.1.0",
  "description": "Ultra-lightweight infinite marquee component for React with native CSS animations",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "marquee",
    "infinite-scroll",
    "carousel",
    "animation",
    "css-animation"
  ],
  "author": "tavosud",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  }
}
